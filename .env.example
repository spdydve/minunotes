TURSO_DB_URL=file:local.db
TURSO_AUTH_TOKEN=

# Better Auth
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:5173/internal/auth
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:5173
COOKIE_DOMAIN=
ALLOWED_LOGIN_EMAILS=you@dpklabs.com
SES_FROM_EMAIL="MinuNotes <notes@dpklabs.com>"
SES_REGION=us-east-1
# Optional for local email test script:
# TEST_EMAIL_TO=you@dpklabs.com

# Custom domains with existing ACM certs (manual DNS via Namecheap)
# WEB_CERT_ARN=arn:aws:acm:us-east-1:...:certificate/...
# API_CERT_ARN=arn:aws:acm:us-east-1:...:certificate/...

# Attachment storage
# Local/Docker default:
ATTACHMENT_STORAGE_DRIVER=filesystem
ATTACHMENT_STORAGE_PATH=.notes-attachments
ATTACHMENT_PUBLIC_BASE_URL=
ATTACHMENT_CLEANUP_GRACE_DAYS=30
# Deployed SST schedule only. Local cleanup can be run manually with `pnpm attachments:cleanup`.
# ATTACHMENT_CLEANUP_SCHEDULE=rate(1 day)

# To test signed S3 uploads during local dev, override with:
# ATTACHMENT_STORAGE_DRIVER=s3
# ATTACHMENT_BUCKET=your-dev-bucket
# ATTACHMENT_REGION=us-east-1
# ATTACHMENT_ENDPOINT=
# ATTACHMENT_FORCE_PATH_STYLE=false

# For S3-compatible storage such as MinIO/Tigris/R2:
# ATTACHMENT_STORAGE_DRIVER=s3-compatible
# ATTACHMENT_BUCKET=notes-dev
# ATTACHMENT_REGION=auto
# ATTACHMENT_ENDPOINT=http://localhost:9000
# ATTACHMENT_FORCE_PATH_STYLE=true

# Browser API base. Use /internal for local Vite proxy.
VITE_API_URL=/internal

# Vite dev proxy target. In SST dev this is injected automatically.
VITE_API_PROXY_TARGET=https://your-api-gateway.execute-api.us-east-1.amazonaws.com
