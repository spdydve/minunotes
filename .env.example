LIBSQL_URL=file:local.db
LIBSQL_AUTH_TOKEN=

# Better Auth
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:5173/api/auth
FRONTEND_URL=http://localhost:5173
COOKIE_DOMAIN=

# Browser API base. Use /api for local Vite proxy.
VITE_API_URL=/api

# Vite dev proxy target. In SST dev this is injected automatically.
VITE_API_PROXY_TARGET=https://your-api-gateway.execute-api.us-east-1.amazonaws.com
