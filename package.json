{
  "name": "minunotes",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@8.15.3",
  "scripts": {
    "dev": "ENVIRONMENT=local TURSO_DB_URL=file:$PWD/local.db sst dev --mode=mono",
    "dev:sst": "ENVIRONMENT=local TURSO_DB_URL=file:$PWD/local.db sst dev",
    "dev:web": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "build": "vite build",
    "deploy": "sst deploy",
    "deploy:dev": "ENVIRONMENT=development sst deploy --stage dev",
    "deploy:production": "ENVIRONMENT=production sst deploy --stage production",
    "remove": "sst remove",
    "remove:dev": "ENVIRONMENT=development sst remove --stage dev",
    "remove:production": "ENVIRONMENT=production sst remove --stage production",
    "email:test": "ENVIRONMENT=local tsx scripts/send-test-email.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:dev": "ENVIRONMENT=development tsx scripts/migrate.ts",
    "db:migrate:production": "ENVIRONMENT=production tsx scripts/migrate.ts",
    "db:wipe:dev": "ENVIRONMENT=development tsx scripts/wipe-db.ts --yes",
    "db:studio": "drizzle-kit studio",
    "attachments:cleanup": "tsx scripts/cleanup-attachments.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/client-sesv2": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@dpklabs/minueditor": "github:spdydve/minueditor#v0.5.1",
    "@hono/node-server": "^2.0.3",
    "@libsql/client": "latest",
    "@radix-ui/react-popover": "^1.1.15",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-table": "latest",
    "better-auth": "^1.6.11",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "drizzle-orm": "latest",
    "hono": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sst": "4.14.3",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "latest",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "drizzle-kit": "latest",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "^4.1.7"
  }
}
